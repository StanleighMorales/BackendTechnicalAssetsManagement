# Logging
Logging__LogLevel__Default=Information!
Logging__LogLevel__Microsoft.AspNetCore=Warning!

# Database Provider Selection
# Options: SqlServer, PostgreSQL, Supabase
DatabaseProvider=SqlServer

# Connection Strings
# Local SQL Server (SSMS)
ConnectionStrings__SqlServer=Server="yourLocalDB";Database="yourDatabase";Trusted_Connection=True;

# Local SQL Server (SQL Electron)
# ConnectionStrings__SqlServer=Server="loopback address","port";Database="yourDatabase";User Id="User";Password="mypassword123";TrustServerCertificate=True;

# Local PostgreSQL
ConnectionStrings__PostgreSQL=Host=localhost;Port=5432;Database=yourDatabase;Username=postgres;Password=yourpassword;

# Supabase PostgreSQL
ConnectionStrings__Supabase=Host=db.yourproject.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=your-supabase-password;SslMode=Require;

# Default Connection (will be set based on DatabaseProvider)
ConnectionStrings__DefaultConnection=

# App Settings
AppSettings__Token="aVeryLockAndSecureSuperDuperLongToken"